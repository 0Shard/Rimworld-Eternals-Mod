<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <!-- Eternal Essence Hediff - Core immortality marker -->
    <HediffDef>
        <defName>Eternal_Essence</defName>
        <hediffClass>Eternal.Eternal_Hediff</hediffClass>
        <label>Eternal Essence</label>
        <description>The biological essence that enables eternal regeneration.</description>
        <initialSeverity>1.0</initialSeverity>
        <isBad>false</isBad>
        <showGizmosOnCorpse>true</showGizmosOnCorpse>
        <stages>
            <li />
        </stages>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>0.0</severityPerDay>
            </li>
        </comps>
    </HediffDef>

    <!-- NEW: Unified Regrowing Hediff with partEfficiencyOffset stages -->
    <!-- Following the Immortals mod pattern - simple hediff tracking body part regrowth -->
    <HediffDef>
        <defName>Eternal_Regrowing</defName>
        <hediffClass>Eternal.EternalRegrowing_Hediff</hediffClass>
        <label>Regrowing</label>
        <description>This body part is regenerating through Eternal essence.</description>
        <initialSeverity>0.01</initialSeverity>
        <isBad>false</isBad>
        <tendable>false</tendable>
        <displayWound>false</displayWound>
        <defaultLabelColor>(0.4, 0.8, 0.4)</defaultLabelColor>
        <stages>
            <li>
                <label>Stage 1</label>
                <minSeverity>0</minSeverity>
                <partEfficiencyOffset>-1.0</partEfficiencyOffset>
            </li>
            <li>
                <label>Stage 2</label>
                <minSeverity>0.25</minSeverity>
                <partEfficiencyOffset>-1.0</partEfficiencyOffset>
            </li>
            <li>
                <label>Stage 3</label>
                <minSeverity>0.5</minSeverity>
                <partEfficiencyOffset>-0.75</partEfficiencyOffset>
            </li>
            <li>
                <label>Stage 4</label>
                <minSeverity>0.75</minSeverity>
                <partEfficiencyOffset>-0.5</partEfficiencyOffset>
            </li>
        </stages>
    </HediffDef>

    <!-- Teleportation Recovery Hediff -->
    <HediffDef>
        <defName>Eternal_TeleportationRecovery</defName>
        <hediffClass>Eternal.Hediffs.EternalTeleportationRecovery_Hediff</hediffClass>
        <label>Teleportation Recovery</label>
        <description>Recovering from teleportation after death in caravan.</description>
        <initialSeverity>1.0</initialSeverity>
        <isBad>true</isBad>
        <tendable>false</tendable>
        <displayWound>false</displayWound>
        <comps>
            <li Class="HediffCompProperties_SeverityPerDay">
                <severityPerDay>-2.0</severityPerDay>
            </li>
        </comps>
    </HediffDef>

    <!-- Metabolic Recovery Hediff -->
    <!-- Applied while a pawn carries food debt from healing/resurrection.
         Severity maps to accumulated food debt: 0.0 = no debt, 1.0 = maximum debt.
         Pure status display: repayment happens via the food-bar drain
         (DebtRepaymentProcessor), NOT via a hunger rate increase. -->
    <HediffDef>
        <defName>Eternal_MetabolicRecovery</defName>
        <hediffClass>Eternal.Hediffs.MetabolicRecovery_Hediff</hediffClass>
        <label>Metabolic Recovery</label>
        <description>This pawn is metabolically recovering from resurrection or healing. The body consumes extra nutrition until the metabolic debt is repaid.</description>
        <initialSeverity>0.01</initialSeverity>
        <minSeverity>0</minSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>true</isBad>
        <tendable>false</tendable>
        <displayWound>false</displayWound>
        <defaultLabelColor>(0.9, 0.6, 0.2)</defaultLabelColor>
        <stages>
            <li>
                <label>minor recovery</label>
                <minSeverity>0.00</minSeverity>
            </li>
            <li>
                <label>moderate recovery</label>
                <minSeverity>0.33</minSeverity>
            </li>
            <li>
                <label>intensive recovery</label>
                <minSeverity>0.66</minSeverity>
            </li>
        </stages>
    </HediffDef>

</Defs>
