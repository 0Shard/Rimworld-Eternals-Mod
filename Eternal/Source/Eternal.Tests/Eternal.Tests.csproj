<!-- Description: xUnit 2.9 + NSubstitute test project targeting net472. -->
<!--              References the production Eternal.csproj for testing all pure-logic surfaces. -->
<!--              Uses Krafs.Rimworld.Ref for compile-time type safety without game runtime. -->
<!--              Note: xUnit v3 requires netstandard2.1 at runtime which net472 cannot provide; -->
<!--              xUnit v2 is the proven path for .NET Framework 4.7.2 projects. -->
<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net472</TargetFramework>
    <IsPackable>false</IsPackable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>Eternal.Tests</RootNamespace>
    <AssemblyName>Eternal.Tests</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <!-- xUnit v2 core: Fact/Theory attributes, Assert class -->
    <PackageReference Include="xunit" Version="2.9.3" />
    <!-- VSTest adapter: enables dotnet test discovery and execution -->
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.13.0" />
    <!-- xUnit console runner: lets the net472 suite run under Mono on Linux/macOS
         (the .NET SDK ships no testhost.net472.exe, so `dotnet test` can't host it). Dev-only. -->
    <PackageReference Include="xunit.runner.console" Version="2.9.3" PrivateAssets="all" />
    <!-- NSubstitute: interface mocking for ISettingsProvider, IPawnData -->
    <PackageReference Include="NSubstitute" Version="5.3.0" />
    <!-- RimWorld reference assemblies: compile-time type safety, no game runtime needed -->
    <PackageReference Include="Krafs.Rimworld.Ref" Version="1.6.4871" />
    <!-- Harmony: patch attribute verification via reflection -->
    <PackageReference Include="Lib.Harmony" Version="2.4.2" />
    <!-- System.Reflection.Metadata: PE metadata inspection for CauseDeathNow IL verification
         (avoids Assembly-CSharp dependency that blocks CLR reflection on Verse.Hediff subclasses) -->
    <PackageReference Include="System.Reflection.Metadata" Version="8.0.1" />
    <!-- net472 reference assemblies via NuGet so the build works on Linux/macOS (no system Developer Pack). -->
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
  </ItemGroup>

  <!-- Reference production project -->
  <ItemGroup>
    <ProjectReference Include="..\Eternal.csproj" />
  </ItemGroup>

</Project>
